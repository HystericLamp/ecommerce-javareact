{
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run frontend\" \"npm run backend\"",
    "frontend": "cd ecommerce-front && npm run dev",
    "backend": "cd ecommerce-backend && cross-env SPRING_PROFILES_ACTIVE=dev ./mvnw spring-boot:run"
  }
}
